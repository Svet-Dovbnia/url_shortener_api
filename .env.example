# Application
PORT=3000
NODE_ENV=development

# Shared secret required by POST /user (x-admin-key header).
# Leave empty for local bootstrap; MUST be set in production.
ADMIN_API_KEY=

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=url_shortener
DB_SYNCHRONIZE=true
DB_LOGGING=false
